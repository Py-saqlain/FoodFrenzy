@model FoodFrenzy.Models.FoodItem
@{
    Layout = null;
}

<!-- FIXED: Added form id="updateForm" -->
<form class="row g-3" method="post" action="/Admin/Update" id="updateForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id">

    <div class="col-md-6">
        <label class="form-label">Name <span class="text-danger">*</span></label>
        <input type="text" class="form-control" name="Name" value="@Model.Name" required maxlength="100">
    </div>

    <div class="col-md-6">
        <label class="form-label">Category <span class="text-danger">*</span></label>
        <input type="text" class="form-control" name="Category" value="@Model.Category" required maxlength="50">
    </div>

    <div class="col-md-6">
        <label class="form-label">Price <span class="text-danger">*</span></label>
        <div class="input-group">
            <span class="input-group-text">Rs</span>
            <!-- FIXED: Added min value -->
            <input type="number" class="form-control" name="Price" value="@Model.Price" step="0.01" min="0.01" max="10000" required>
        </div>
    </div>

    <div class="col-md-6">
        <label class="form-label">Rating <span class="text-danger">*</span></label>
        <!-- FIXED: FoodItem model has double Rating -->
        <input type="number" step="0.1" class="form-control" name="Rating" value="@Model.Rating" min="0" max="5" required>
    </div>

    <div class="col-md-6">
        <label class="form-label">Availability <span class="text-danger">*</span></label>
        <!-- FIXED: Correctly set selected option -->
        <select class="form-select" name="IsAvailable" required>
            <option value="true" selected="@Model.IsAvailable">Available</option>
            <option value="false" selected="@(!Model.IsAvailable)">Not Available</option>
        </select>
    </div>

    <div class="col-12">
        <label class="form-label">Description <span class="text-danger">*</span></label>
        <textarea class="form-control" rows="3" name="Description" required maxlength="500">@Model.Description</textarea>
    </div>

    <div class="col-12">
        <label class="form-label">Image URL</label>
        <input type="text" class="form-control" name="ImageUrl" value="@Model.ImageUrl" placeholder="Enter image URL">
    </div>

    <div class="col-12 mt-4">
        <button type="submit" class="btn btn-warning w-100 py-2" id="updateSubmitBtn">
            <i class="fas fa-save me-2"></i>Update Food Item
        </button>
    </div>
</form>

<script>
    // FIXED: Use DOMContentLoaded to ensure form is loaded
    document.addEventListener('DOMContentLoaded', function() {
        const updateForm = document.getElementById('updateForm');
        if (updateForm) {
            // Fix the IsAvailable dropdown selection
            const isAvailableSelect = updateForm.querySelector('[name="IsAvailable"]');
            const isAvailableValue = '@Model.IsAvailable' === 'True' ? 'true' : 'false';

            for (let option of isAvailableSelect.options) {
                option.selected = option.value === isAvailableValue;
            }

            // Form submission handler
            updateForm.addEventListener('submit', function(e) {
                const submitBtn = document.getElementById('updateSubmitBtn');
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Updating...';
                }
            });
        }
    });
</script>