<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FoodFrenzy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/FoodFrenzy.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/index.css">
        <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
    @RenderSection("Styles", required: false)

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg custom-navbar">
            <div class="container">
                <a class="navbar-brand logo" asp-controller="Home" asp-action="Index">
                    <h1>Food<span>Frenzy</span></h1>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent"
                        aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 custom-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Explore" asp-action="Index">Explore</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="About" asp-action="Index">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link " asp-controller="Contact" asp-action="Index">Contact</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center header-actions">
                        <div class="cart-icon me-3 position-relative">
                            <a asp-controller="Cart" asp-action="Index" class="text-decoration-none text-dark">
                                <i class="fas fa-shopping-cart fs-5"></i>
                                <span class="cart-count position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cartCountBadge" style="display: none;">
                                    0
                                </span>
                            </a>
                        </div>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <!-- Authenticated User Menu -->
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="Index" class="me-2">
                                    <button class="btn btn-custom">Admin Panel</button>
                                </a>
                            }

                            <a asp-controller="Profile" asp-action="Index" class="me-2">
                                <button class="btn btn-profile">
                                    <i class="fas fa-user"></i>
                                </button>
                            </a>

                            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-custom">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="me-2">
                                <button class="btn btn-custom">Login</button>
                            </a>
                            <a asp-area="Identity" asp-page="/Account/Register">
                                <button class="btn btn-custom">Register</button>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        <!-- Display success/error messages -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="footer-content">
                <div class="footer-column">
                    <h3>FoodFrenzy</h3>
                    <p>Delivering delicious meals to your doorstep with speed and quality you can trust.</p>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>

                <div class="footer-column">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="About" asp-action="Index">About Us</a></li>
                        <li><a asp-controller="Explore" asp-action="Index">Services</a></li>
                        <li><a asp-controller="Explore" asp-action="Index">Menu</a></li>
                        <li><a asp-controller="Contact" asp-action="Index">Contact</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h3>Categories</h3>
                    <ul>
                        <li><a href="#">Burgers</a></li>
                        <li><a href="#">Pizza</a></li>
                        <li><a href="#">Pasta</a></li>
                        <li><a href="#">Desserts</a></li>
                        <li><a href="#">Drinks</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h3>Contact Us</h3>
                    <ul>
                        <li><i class="fas fa-map-marker-alt"></i> 12-K, Johar Town, Lahore, Pakistan</li>
                        <li><i class="fas fa-phone"></i> +92 300 1234567</li>
                        <li><i class="fas fa-envelope"></i> support@FoodFrenzy.pk</li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <p>&copy; 2025 FoodFrenzy. All rights reserved.</p>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Global Cart Script -->
    <script>
        // Function to update cart count
        function updateCartCount(count) {
            const cartCountBadge = document.getElementById('cartCountBadge');
            if (cartCountBadge) {
                cartCountBadge.textContent = count;
                cartCountBadge.style.display = count > 0 ? 'block' : 'none';
            }
        }

        // Load cart count on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Load initial cart count
            fetch('/Cart/GetCartCount')
                .then(response => response.json())
                .then(data => {
                    updateCartCount(data.count);
                })
                .catch(error => {
                    console.error('Error loading cart count:', error);
                });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>